generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password_hash  String
  role           Role
  name           String
  phone          String?
  created_at     DateTime        @default(now())
  clientProfiles ClientProfile[]
  ownerProfiles  OwnerProfile[]
  staffProfiles  StaffProfile[]
}

model Business {
  id                    String          @id @default(uuid())
  name                  String
  slug                  String          @unique
  location              String?
  phone                 String?
  timezone              String          @default("UTC")
  slot_interval_minutes Int             @default(30)
  settings_json         Json?
  created_at            DateTime        @default(now())
  appointments          Appointment[]
  clientProfiles        ClientProfile[]
  ownerProfiles         OwnerProfile[]
  services              Service[]
  staffProfiles         StaffProfile[]
}

model OwnerProfile {
  id          String   @id @default(uuid())
  user_id     String
  business_id String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  business    Business @relation(fields: [business_id], references: [id])
  user        User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, business_id])
  @@index([business_id], map: "OwnerProfile_business_id_fkey")
}

model StaffProfile {
  id           String         @id @default(uuid())
  user_id      String
  business_id  String
  is_active    Boolean        @default(true)
  created_at   DateTime       @default(now())
  appointments Appointment[]
  schedules    Schedule[]
  business     Business       @relation(fields: [business_id], references: [id])
  user         User           @relation(fields: [user_id], references: [id])
  services     StaffService[]
  timeOffs     TimeOff[]

  @@unique([user_id, business_id])
  @@index([business_id], map: "StaffProfile_business_id_fkey")
}

model ClientProfile {
  id           String        @id @default(uuid())
  user_id      String
  business_id  String
  notes        String?       @db.Text
  created_at   DateTime      @default(now())
  appointments Appointment[]
  business     Business      @relation(fields: [business_id], references: [id])
  user         User          @relation(fields: [user_id], references: [id])

  @@unique([user_id, business_id])
  @@index([business_id], map: "ClientProfile_business_id_fkey")
}

model Service {
  id           String         @id @default(uuid())
  business_id  String
  name         String
  duration_min Int            @default(30)
  price        Decimal        @db.Decimal(10, 2)
  is_active    Boolean        @default(true)
  appointments Appointment[]
  business     Business       @relation(fields: [business_id], references: [id])
  staff        StaffService[]

  @@index([business_id], map: "Service_business_id_fkey")
}

model StaffService {
  staff_id   String
  service_id String
  service    Service      @relation(fields: [service_id], references: [id])
  staff      StaffProfile @relation(fields: [staff_id], references: [id])

  @@id([staff_id, service_id])
  @@index([service_id], map: "StaffService_service_id_fkey")
}

model Schedule {
  id          String       @id @default(uuid())
  staff_id    String
  day_of_week Int
  start_time  String
  end_time    String
  staff       StaffProfile @relation(fields: [staff_id], references: [id])

  @@index([staff_id], map: "Schedule_staff_id_fkey")
}

model TimeOff {
  id                 String       @id @default(uuid())
  staff_id           String
  start_datetime_utc DateTime
  end_datetime_utc   DateTime
  reason             String?
  staff              StaffProfile @relation(fields: [staff_id], references: [id])

  @@index([staff_id], map: "TimeOff_staff_id_fkey")
}

model Appointment {
  id                      String            @id @default(uuid())
  business_id             String
  client_id               String?
  staff_id                String
  service_id              String
  start_datetime_utc      DateTime
  end_datetime_utc        DateTime
  status                  AppointmentStatus @default(PENDING_CONFIRMATION)
  confirmation_token      String?           @unique
  confirmation_expires_at DateTime?
  confirmed_at            DateTime?
  reminder_sent_at        DateTime?
  business                Business          @relation(fields: [business_id], references: [id])
  client                  ClientProfile?    @relation(fields: [client_id], references: [id])
  service                 Service           @relation(fields: [service_id], references: [id])
  staff                   StaffProfile      @relation(fields: [staff_id], references: [id])

  @@index([staff_id, start_datetime_utc])
  @@index([business_id], map: "Appointment_business_id_fkey")
  @@index([client_id], map: "Appointment_client_id_fkey")
  @@index([service_id], map: "Appointment_service_id_fkey")
}

enum Role {
  SUPERADMIN
  OWNER
  STAFF
  CLIENT
}

enum AppointmentStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  COMPLETED
  CANCELLED
}
